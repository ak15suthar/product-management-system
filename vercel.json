{
  "version": 2,
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "frontend/dist/frontend/browser",
  "installCommand": "cd backend && npm install && cd ../frontend && npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
